APP_ENV=dev

# API
API_PORT=8080
JWT_SECRET=dev_secret_change_me

# MySQL
MYSQL_DATABASE=appdb
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306
MYSQL_DSN=app:app@tcp(mysql:3306)/appdb?parseTime=true&charset=utf8mb4&loc=Local

# Redis
REDIS_ADDR=redis:6379
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

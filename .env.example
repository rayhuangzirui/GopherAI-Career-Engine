APP_ENV=dev

# API
API_PORT=8080
JWT_SECRET=dev_secret_change_me

# MySQL
MYSQL_DATABASE=appdb
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306
MYSQL_DSN=app:app@tcp(mysql:3306)/appdb?parseTime=true&charset=utf8mb4&loc=Local

# Redis
REDIS_ADDR=redis:6379
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Analyzer / LLM
ANALYZER_MODE=llm
LLM_PROVIDER=dashscope
LLM_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
DASHSCOPE_API_KEY=
LLM_MODEL=qwen-plus
LLM_TIMEOUT_SECONDS=20
LLM_TEMPERATURE=0.2
LLM_MAX_INPUT_CHARS=8000
LLM_MAX_OUTPUT_TOKENS=800

# Redis-backed rate limit / cache
RATE_LIMIT_PER_MINUTE=10
TASK_CACHE_TTL_SECONDS=60
TASK_LIST_CACHE_TTL_SECONDS=10
TASK_RESULT_CACHE_TTL_SECONDS=300

# Artifact storage
ARTIFACT_STORAGE_DRIVER=local
ARTIFACT_LOCAL_BASE_DIR=/app/data

# AWS / S3
AWS_REGION=
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false